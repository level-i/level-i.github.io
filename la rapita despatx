<!DOCTYPE html>
<html lang="ca">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Level-i | Oficina Virtual Interactiva i Simulador</title>
    <style>
        :root {
            --verde-oscuro: #1b4332;
            --verde-clar: #2d6a4f;
            --dorado: #d4af37;
            --blanco: #ffffff;
            --gris-claro: #f4f4f9;
            --glass: rgba(27, 67, 50, 0.95);
        }
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; font-family: 'Segoe UI', sans-serif; background: #000; color: #fff; }
        
        .fullscreen-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
        #main-layout { display: none; width: 100%; height: 100%; position: relative; overflow-y: auto; background: var(--verde-oscuro); }

        /* Estructura split (VR dalt, dades baix si s'activa) */
        .split-vr { width: 100%; height: 100vh; position: relative; background: #000; }

        /* HUD de l'Advisor Virtual */
        .hud-overlay {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            z-index: 10; width: 92%; max-width: 550px;
            background: var(--glass); backdrop-filter: blur(12px);
            border: 2px solid var(--dorado); border-radius: 15px;
            padding: 30px; text-align: center; color: var(--blanco);
            box-shadow: 0 0 35px rgba(212, 175, 55, 0.3);
            box-sizing: border-box;
        }
        
        .avatar-container {
            width: 120px; height: 120px; margin: 0 auto 15px auto;
            border-radius: 50%; border: 3px solid var(--dorado);
            overflow: hidden; background: #000; box-shadow: 0 0 15px rgba(212, 175, 55, 0.4);
        }
        .avatar-img { width: 100%; height: 100%; object-fit: cover; }
        .hud-title { color: var(--dorado); font-size: 24px; margin-bottom: 15px; font-weight: bold; letter-spacing: 1px; }
        .hud-text { font-size: 16px; line-height: 1.6; margin-bottom: 25px; text-align: left; }
        
        .btn-hud, button, .btn-link {
            background: transparent; color: var(--blanco); border: 2px solid var(--blanco);
            padding: 12px 24px; font-size: 15px; font-weight: bold; border-radius: 5px;
            cursor: pointer; margin: 8px; transition: 0.3s; text-decoration: none; display: inline-block;
        }
        .btn-hud:hover, button:hover, .btn-link:hover { background: var(--dorado); color: #000; border-color: var(--dorado); }
        
        input[type="text"], input[type="email"], input[type="tel"], input[type="number"] {
            width: 100%; padding: 12px; margin-bottom: 15px; border-radius: 5px;
            border: 1px solid var(--dorado); background: rgba(0,0,0,0.6); color: #fff; font-size: 16px; box-sizing: border-box;
        }

        /* Secció Financera (S'activa al final) */
        .financial-section { display: none; padding: 40px 20px; max-width: 1100px; margin: 0 auto; }
        .section { background: rgba(255, 255, 255, 0.05); padding: 25px; border-radius: 10px; margin-bottom: 25px; }
        
        /* Galeria */
        .tab-container { display: flex; gap: 10px; margin-bottom: 15px; }
        .tab-btn { background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.2); padding: 10px 20px; border-radius: 5px; cursor: pointer; font-weight: bold; }
        .tab-btn.active { background: var(--verde-clar); border-color: var(--dorado); }
        .gallery-pane { display: none; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; }
        .gallery-pane.active { display: grid; }
        .gallery-item { width: 100%; border-radius: 6px; aspect-ratio: 4/3; object-fit: cover; border: 1px solid rgba(255,255,255,0.1); }

        /* Taula */
        .table-responsive { width: 100%; overflow-x: auto; margin-top: 15px; border-radius: 5px; }
        table { width: 100%; border-collapse: collapse; background: #fff; color: #333; min-width: 900px; font-size: 14px; }
        th, td { padding: 10px 12px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background-color: var(--verde-clar); color: #fff; }
        tr:nth-child(even) { background-color: var(--gris-claro); }
        .flex-inputs { display: flex; gap: 20px; align-items: center; flex-wrap: wrap; }

        /* Modal final */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--verde-oscuro); z-index: 9999; overflow-y: auto; }
        .modal-content { max-width: 800px; margin: 0 auto; padding: 60px 20px; text-align: center; }
    </style>
    <script src="https://www.youtube.com/iframe_api"></script>
</head>
<body>

    <div id="player" class="fullscreen-bg"></div>

    <div id="main-layout">
        
        <div class="split-vr">
            <iframe src="https://floorplanner.com/360vr/161201146-1784390472" width="100%" height="100%" style="border:none;"></iframe>
            
            <div id="avatar-hud" class="hud-overlay">
                <div class="avatar-container">
                    <img src="foto-actual1.jpg" alt="Level AI Advisor" class="avatar-img" id="avatar-view">
                </div>
                <div class="hud-title">LEVEL AI ADVISORS</div>
                <div class="hud-text" id="hud-speech">Configurant connexió...</div>
                <div id="hud-actions"></div>
            </div>
        </div>

        <div id="financial-module" class="financial-section">
            
            <div class="section" style="border: 1px solid var(--dorado); background: rgba(212, 175, 55, 0.05);">
                <h2 style="margin-top:0;" id="txt-eco-title">Ecosistema Level-i: L'Avantatge de ser Partner Local</h2>
                <p id="txt-eco-p">L'empresa propietària d'aquest espai té la capacitat d'actuar simultàniament com a <strong>Advisor i Partner Local</strong> de la xarxa, fet que multiplica exponencialment el retorn de la inversió:</p>
                <ul style="line-height: 1.6;" id="txt-eco-list">
                    <li><strong>Accés Preferent (Off-Market):</strong> Detecció d'actius exclusius abans de la seva publicació general.</li>
                    <li><strong>Senyalització Immediata:</strong> Capacitat de bloquejar operacions de forma àgil.</li>
                    <li><strong>Passi a Tercers:</strong> Generació d'ingressos addicionals cedit oportunitats calentes a la comunitat.</li>
                </ul>
            </div>

            <div class="section">
                <h2 id="txt-gal-title">Evolució Visual del Projecte</h2>
                <div class="tab-container">
                    <button class="tab-btn active" onclick="switchGallery('actuals', this)">Estat Actual</button>
                    <button class="tab-btn" onclick="switchGallery('renders', this)">Projecte (Renders 3D)</button>
                </div>
                <div id="gallery-actuals" class="gallery-pane active">
                    <img src="foto-actual1.jpg" class="gallery-item"><img src="foto-actual2.jpg" class="gallery-item"><img src="foto-actual3.jpg" class="gallery-item"><img src="foto-actual4.jpg" class="gallery-item"><img src="foto-actual5.jpg" class="gallery-item}
                </div>
                <div id="gallery-renders" class="gallery-pane">
                    <img src="render1.jpg" class="gallery-item"><img src="render2.jpg" class="gallery-item"><img src="render3.jpg" class="gallery-item"><img src="render4.jpg" class="gallery-item"><img src="render5.jpg" class="gallery-item">
                </div>
            </div>

            <div class="section">
                <h2 id="txt-calc-title">Estudi Econòmic i Amortització Real (A 10 anys)</h2>
                <div style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                    <h3 id="txt-sim-title">Simulador de Palanquejament Financer</h3>
                    <div class="flex-inputs">
                        <label id="txt-sim-munt">Import a finançar (€): <input type="number" id="input-hipoteca" value="0" min="0" max="22150" oninput="calcularFinances()"></label>
                        <label id="txt-sim-int">Interès Fixe (%): <input type="number" id="input-interes" value="3.5" step="0.1" oninput="calcularFinances()"></label>
                    </div>
                </div>

                <h3 id="txt-desglos-title">Desglòs Inicial i Fons Propis</h3>
                <ul style="line-height: 1.6;" id="txt-desglos-list">
                    <li>Valor Compravenda: 35.000 €</li>
                    <li>Honoraris Level.immo: 7.000 €</li>
                    <li>IVA (21% s/ 35k): 7.350 €</li>
                    <li>Notaria i Registre (Estimat): 1.500 €</li>
                    <li>Reforma Integral (Claus en mà, inclou permisos): 20.000 €</li>
                </ul>
                <p style="font-size:1.2rem; color:var(--dorado);">Capital Propi Real Aportat: <span id="capital-propi-real">70.850</span> €</p>

                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr id="table-head">
                                <th>Concepte</th><th>Any 1</th><th>Any 2</th><th>Any 3</th><th>Any 4</th><th>Any 5</th><th>Any 6</th><th>Any 7</th><th>Any 8</th><th>Any 9</th><th>Any 10</th>
                            </tr>
                        </thead>
                        <tbody id="table-body">
                            </tbody>
                    </table>
                </div>

                <div style="text-align: center; margin-top: 40px;">
                    <button style="font-size: 18px;" onclick="obrirModal()" id="btn-modal-trigger">Què passarà en 5 anys? Descobreix el valor futur</button>
                </div>
            </div>
        </div>
    </div>

    <div id="modal-futur" class="modal">
        <div class="modal-content">
            <h2 id="txt-m-title">Potencial de Revalorització a 5 Anys</h2>
            <p id="txt-m-p1">Donat que actualment hi ha una manca absoluta de construcció d'obra nova i una altíssima demanda d'habitatge a La Ràpita, aquest immoble té un as a la màniga.</p>
            <p id="txt-m-p2">Aquest local de <strong>95m² edificats del 2008</strong>, cèntric, amb pati de llums, ascensor i sol de tarda, compleix els requisits tècnics per a un <strong>hipotètic canvi d'ús a vivenda</strong>.</p>
            <p id="txt-m-p3">Un cop transformat en un impressionant loft de disseny, el valor de mercat estimat en 5 anys podria superar fàcilment els <strong>110.000€ - 120.000€</strong>, multiplicant el retorn de la teva inversió inicial.</p>
            <div style="margin-top: 40px;">
                <a href="https://level-i.github.io/" target="_blank" class="btn-link" style="background-color: var(--blanco); color:#000;">Consultar Assistenta VR</a>
                <button onclick="tancarModal()" style="background:transparent; border:2px solid #fff;">Tornar enrere</button>
            </div>
        </div>
    </div>

<script>
    let player;
    let usuariDades = { idioma: 'ca', nom: '', email: '', mobil: '', nomBot: '' };

    function onYouTubeIframeAPIReady() {
        player = new YT.Player('player', {
            videoId: 'rx-Fz4qeNoo',
            playerVars: { 'autoplay': 1, 'controls': 0, 'rel': 0, 'showinfo': 0, 'modestbranding': 1, 'iv_load_policy': 3 },
            events: { 'onStateChange': onPlayerStateChange }
        });
    }

    function onPlayerStateChange(event) {
        if (event.data === YT.PlayerState.ENDED) {
            document.getElementById('player').style.display = 'none';
            document.getElementById('main-layout').style.display = 'block';
            triaIdioma();
        }
    }

    function parlar(text, idioma) {
        window.speechSynthesis.cancel();
        const iaspeech = new SpeechSynthesisUtterance(text);
        iaspeech.lang = idioma === 'ca' ? 'ca-ES' : 'es-ES';
        window.speechSynthesis.speak(iaspeech);
    }

    function triaIdioma() {
        document.getElementById('hud-speech').innerText = "Vols que parlem en català o prefieres en castellano?";
        document.getElementById('hud-actions').innerHTML = `
            <button class="btn-hud" onclick="iniciarAdvisor('ca')">Català</button>
            <button class="btn-hud" onclick="iniciarAdvisor('es')">Castellano</button>
        `;
    }

    function iniciarAdvisor(idioma) {
        usuariDades.idioma = idioma;
        traduirInterficie(idioma);
        const text = idioma === 'ca' 
            ? "Hola. Sóc la teva Assistenta Virtual de Level AI Advisors. Encara no m'han posat nom. Em vols batejar tu?"
            : "Hola. Soy tu Asistenta Virtual de Level AI Advisors. Todavía no me han puesto nombre. ¿Quieres bautizarme tú?";
        document.getElementById('hud-speech').innerText = text;
        parlar(text, idioma);
        document.getElementById('hud-actions').innerHTML = `
            <button class="btn-hud" onclick="mostrarBateig(true)">Sí</button>
            <button class="btn-hud" onclick="mostrarBateig(false)">No</button>
        `;
    }

    function mostrarBateig(volBatejar) {
        const idioma = usuariDades.idioma;
        if(volBatejar) {
            document.getElementById('hud-speech').innerText = idioma === 'ca' ? "Escriu el nom que em vols posar:" : "Escribe el nombre que me quieres poner:";
            document.getElementById('hud-actions').innerHTML = `
                <input type="text" id="botname-input" placeholder="Nom...">
                <button class="btn-hud" onclick="guardarNomBot()">Ok</button>
            `;
        } else { preguntarNomUsuari(); }
    }

    function guardarNomBot() {
        let nomProvisional = document.getElementById('botname-input').value || "Advisor";
        usuariDades.nomBot = nomProvisional;
        const idioma = usuariDades.idioma;
        const text = idioma === 'ca' ? `"${nomProvisional}"... m'ho pensaré.` : `"${nomProvisional}"... me lo pensaré.`;
        document.getElementById('hud-speech').innerText = text;
        parlar(text, idioma);
        setTimeout(preguntarNomUsuari, 2200);
    }

    function preguntarNomUsuari() {
        const idioma = usuariDades.idioma;
        const text = idioma === 'ca' ? "Com et dius tu?" : "¿Cómo te llamas tú?";
        document.getElementById('hud-speech').innerText = text;
        parlar(text, idioma);
        document.getElementById('hud-actions').innerHTML = `
            <input type="text" id="username-input" placeholder="Nom...">
            <button class="btn-hud" onclick="guardarNomUsuari()">Continuar</button>
        `;
    }

    function guardarNomUsuari() {
        let nom = document.getElementById('username-input').value || "Inversor";
        usuariDades.nom = nom;
        const idioma = usuariDades.idioma;
        const text = idioma === 'ca'
            ? `Encantada, ${nom}. És un plaer informar-te a prop d'aquesta inversió. Però abans digues-me: T'interessa adquirir aquesta propietat per reformar-la per a la seva primera activitat, i llogar-la a una marca amb futur?`
            : `Encantada, ${nom}. Es un placer informarte acerca de esta inversión. Pero antes dime: ¿Te interesa adquirir esta propiedad para reformarla para su primera actividad, y alquilarla a una marca con futuro?`;
        document.getElementById('hud-speech').innerText = text;
        parlar(text, idioma);
        document.getElementById('hud-actions').innerHTML = `
            <button class="btn-hud" onclick="interesaPropietat(true)">Sí</button>
            <button class="btn-hud" onclick="interesaPropietat(false)">No</button>
        `;
    }

    function interesaPropietat(interesa) {
        const idioma = usuariDades.idioma;
        if(!interesa) {
            const textNo = idioma === 'ca' ? `D'acord, ${usuariDades.nom}. Que tinguis un bon dia.` : `De acuerdo, ${usuariDades.nom}. Que tengas un buen día.`;
            document.getElementById('hud-speech').innerText = textNo;
            parlar(textNo, idioma);
            document.getElementById('hud-actions').innerHTML = "";
            return;
        }
        const textSi = idioma === 'ca'
            ? "Aquesta inversió consisteix en l'adquisició d'un local comercial per a la seva primera ocupació. L'edifici data de l'any 2007, disposa d'ascensor. Està en ple centre de la Ràpita. La superfície és de 85 metres quadrats, i disposa de lavabo i pati de llums. Té dos grans finestrals a l'Avinguda dels Esports, juntament amb el supermercat Condis. Segons els nostres tècnics, hi ha possibilitat de sol·licitar canvi d'ús en un futur immediat. El preu de venda és de 42.000€, i requereix una inversió de 20.000€, clau en mà. Li pot interessar?"
            : "Esta inversión consiste en la adquisición de un local comercial para su primera ocupación. El edificio data del año 2007, dispone de ascensor. Está en pleno centro de la Rápita. La superficie es de 85 metros cuadrados, y dispone de lavabo y patio de luces. Tiene dos ventanales a l’Avinguda dels Esports, junto el supermercado Condis. Según nuestros técnicos, existe posibilidad de solicitar cambio de uso en un futuro inmediato. El precio de venta es de 42.000€, y requiere una inversión de 20.000€, llave en mano. ¿Le puede interesar?";
        document.getElementById('hud-speech').innerText = textSi;
        parlar(textSi, idioma);
        document.getElementById('hud-actions').innerHTML = `
            <button class="btn-hud" onclick="tancamentComercial()">Sí</button>
            <button class="btn-hud" onclick="interesaPropietat(false)">No</button>
        `;
    }

    function tancamentComercial() {
        const idioma = usuariDades.idioma;
        document.getElementById('hud-speech').innerText = idioma === 'ca' ? "Perfecte! Deixa'ns el teu contacte per bloquejar la propietat 24h sense compromís i veure el mòdul financer complet:" : "¡Perfecto! Déjanos tu contacto para bloquear la propiedad 24h sin compromiso y ver el módulo financiero completo:";
        document.getElementById('hud-actions').innerHTML = `
            <input type="email" id="final-email" placeholder="Email..." required>
            <input type="tel" id="final-tel" placeholder="Mòbil..." required>
            <button class="btn-hud" onclick="activarSimulador()">Desbloquejar Estudi Financer</button>
        `;
    }

    function activarSimulador() {
        let mail = document.getElementById('final-email').value;
        let telf = document.getElementById('final-tel').value;
        if(mail === "" || telf === "") return;
        
        document.getElementById('avatar-hud').style.display = 'none'; // Tanquem el xat
        document.getElementById('financial-module').style.display = 'block'; // Mostrem els números sota el VR
        calcularFinances();
        
        // Scroll automàtic cap als números
        document.getElementById('main-layout').scrollTo({ top: window.innerHeight, behavior: 'smooth' });
    }

    function calcularFinances() {
        const costTotalProjecte = 70850;
        let hipoteca = parseFloat(document.getElementById('input-hipoteca').value) || 0;
        let interes = parseFloat(document.getElementById('input-interes').value) || 0;
        
        if (hipoteca > 22150) { hipoteca = 22150; document.getElementById('input-hipoteca').value = 22150; }
        let fonsPropisReals = costTotalProjecte - hipoteca;
        document.getElementById('capital-propi-real').innerText = fonsPropisReals.toLocaleString('ca-ES');
        
        let quotaMensual = 0;
        if (hipoteca > 0 && interes > 0) {
            let i = (interes / 100) / 12;
            quotaMensual = hipoteca * (i * Math.pow(1 + i, 180)) / (Math.pow(1 + i, 180) - 1);
        }
        let quotaAnual = quotaMensual * 12;
        let ingressos = [4800, 6000, 7200, 7344, 7488, 7632, 7788, 7944, 8100, 8268];
        
        let htmlRows = `
            <tr><td><strong>${usuariDades.idioma==='ca'?'Lloguer Mensual':'Alquiler Mensual'}</strong></td>${ingressos.map((ing, idx)=>`<td>${idx===0?400:idx===1?500:idx===2?600:400+Math.round((ing-4800)/12)}€</td>`).join('')}</tr>
            <tr><td><strong>${usuariDades.idioma==='ca'?'Ingressos Bruts':'Ingresos Brutos'}</strong></td>${ingressos.map(ing=>`<td>${ing}€</td>`).join('')}</tr>
            <tr><td><strong>${usuariDades.idioma==='ca'?'Despeses (IBI)':'Gastos (IBI)'}</strong></td>${ingressos.map(()=>`<td>-700€</td>`).join('')}</tr>
            <tr><td><strong>${usuariDades.idioma==='ca'?'Quota Bancària':'Cuota Bancaria'}</strong></td>${ingressos.map(()=>`<td>-${Math.round(quotaAnual)}€</td>`).join('')}</tr>
            <tr style="background-color: #e2ece9; font-weight: bold;"><td>Cash-Flow Net</td>${ingressos.map(ing=>`<td>${Math.round(ing - 700 - quotaAnual)}€</td>`).join('')}</tr>
            <tr style="background-color: #fff3cd; font-weight: bold; color: #000;"><td>ROI s/ Fons Propis</td>${ingressos.map(ing=>{ let net = ing - 700 - quotaAnual; return `<td>${((net/fonsPropisReals)*100).toFixed(2)}%</td>`; }).join('')}</tr>
        `;
        document.getElementById('table-body').innerHTML = htmlRows;
    }

    function switchGallery(type, btn) {
        document.getElementById('gallery-actuals').classList.remove('active');
        document.getElementById('gallery-renders').classList.remove('active');
        const buttons = document.getElementsByClassName('tab-btn');
        for(let i=0; i<buttons.length; i++) { buttons[i].classList.remove('active'); }
        document.getElementById('gallery-' + type).classList.add('active');
        btn.classList.add('active');
    }

    function traduirInterficie(idioma) {
        if(idioma === 'es') {
            document.getElementById('txt-eco-title').innerText = "Ecosistema Level-i: La Ventaja de ser Partner Local";
            document.getElementById('txt-eco-p').innerHTML = "La empresa propietaria de este espacio tiene la capacidad de actuar simultáneamente como <strong>Advisor y Partner Local</strong> de la red:";
            document.getElementById('txt-eco-list').innerHTML = "<li><strong>Acceso Preferente (Off-Market):</strong> Detección de activos exclusivos antes de su publicación general.</li><li><strong>Señalización Inmediata:</strong> Capacidad de bloquear operaciones de forma ágil.</li><li><strong>Pase a Terceros:</strong> Ingresos adicionales cediendo oportunidades a la comunidad.</li>";
            document.getElementById('txt-gal-title').innerText = "Evolución Visual del Proyecto";
            document.getElementById('txt-calc-title').innerText = "Estudio Económico y Amortización Real (A 10 años)";
            document.getElementById('txt-sim-title').innerText = "Simulador de Apalancamiento Financiero";
            document.getElementById('txt-sim-munt').innerHTML = "Importe a financiar (€): <input type='number' id='input-hipoteca' value='0' oninput='calcularFinances()'>";
            document.getElementById('txt-sim-int').innerHTML = "Interés Fijo (%): <input type='number' id='input-interes' value='3.5' step='0.1' oninput='calcularFinances()'>";
            document.getElementById('txt-desglos-title').innerText = "Desglose Inicial y Capital Propio";
            document.getElementById('btn-modal-trigger').innerText = "¿Qué pasará en 5 años? Descubre el valor futuro";
        }
    }

    function obrirModal() { document.getElementById('modal-futur').style.display = 'block'; }
    function tancarModal() { document.getElementById('modal-futur').style.display = 'none'; }
</script>
</body>
</html>
